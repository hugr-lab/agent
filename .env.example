HUGR_URL=http://localhost:15000

# Auth (pick one):

# 1. Token exchange (production — JupyterHub / isolated container)
# HUGR_ACCESS_TOKEN=eyJhbG...
# HUGR_TOKEN_URL=http://hub-service:8080/token

# 2. OIDC browser flow (dev — opens browser for login)
# HUGR_OIDC_ISSUER=http://localhost:8080/realms/hugr
# HUGR_OIDC_CLIENT_ID=hugr-agent

# 3. Secret key (dev legacy)
HUGR_SECRET_KEY=your-secret-key

# Agent
AGENT_MODEL=gemma4-26b
AGENT_PORT=10000
