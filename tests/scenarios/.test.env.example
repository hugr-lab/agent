# Scenario-runner environment. Copy to tests/scenarios/.test.env
# (gitignored) and fill in per your local setup.
#
# Minimum required — scenarios t.Skip() when these are absent:
LLM_LOCAL_URL=http://host.docker.internal:1234/v1/chat/completions
EMBED_LOCAL_URL=http://host.docker.internal:1234/v1/embeddings

# Optional — routes the default model intent to something other than
# gemma4-26b (must still be a name registered in local_db.models of
# tests/scenarios/config.yaml):
# INTEGRATION_AGENT_MODEL=gemma-small

# Optional — persist hub.db at a fixed path instead of the default
# tests/scenarios/.data/<name>-<ts>/memory.db:
# SCENARIO_PERSIST=/tmp/hugr-scenario.db

# Optional — drop the hub.db file after the scenario finishes. Useful
# for CI-style "just check it runs" smoke tests.
# DROP_DB=1
